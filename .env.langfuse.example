# LangFuse Observability Configuration
# 
# This file contains example configuration for LangFuse integration.
# Copy this file to .env and fill in your actual values.

# LangFuse API Keys
# Get these from your LangFuse Dashboard: Settings → API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxx

# LangFuse Host URL
# - For self-hosted LangFuse: http://your-langfuse-host:3000
# - For LangFuse Cloud: https://cloud.langfuse.com
LANGFUSE_HOST=http://localhost:3000

# ============================================================================
# Quick Start Guide
# ============================================================================
#
# 1. Get LangFuse API Keys:
#    - If you have a deployed LangFuse instance:
#      a. Login to your LangFuse Dashboard
#      b. Go to Settings → API Keys
#      c. Create a new API Key or copy existing one
#      d. Copy the Public Key (pk-lf-...) and Secret Key (sk-lf-...)
#
#    - If you don't have LangFuse yet (use Docker):
#      a. mkdir -p langfuse && cd langfuse
#      b. curl -o docker-compose.yml https://raw.githubusercontent.com/langfuse/langfuse/main/docker-compose.yml
#      c. docker-compose up -d
#      d. Visit http://localhost:3000 and create an account
#      e. Go to Settings → API Keys and create a new key
#
# 2. Copy this file:
#    cp .env.langfuse.example .env
#
# 3. Edit .env and replace the xxx values with your actual keys
#
# 4. Restart the backend service:
#    docker-compose -f docker-compose-dev.yml restart langgraph-api
#
# 5. Verify the integration:
#    - Run a research session from the frontend
#    - Check your LangFuse Dashboard for traces
#    - Look for "WebSocket Research Session" traces
#
# ============================================================================
# Security Notes
# ============================================================================
#
# ⚠️  IMPORTANT: 
# - Never commit .env file to Git (it's already in .gitignore)
# - Keep your Secret Key confidential
# - Use different keys for development and production
# - Rotate keys periodically
#
# ============================================================================
