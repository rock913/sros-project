FROM python:3.11-slim

# Install system dependencies
RUN apt-get update && apt-get install -y git curl build-essential && rm -rf /var/lib/apt/lists/*

# Install Aider, FastMCP SDK and common tools
RUN pip install --no-cache-dir aider-chat fastmcp mcp-server ruff pytest pydantic-ai python-dotenv

# Set working directory
WORKDIR /app

# Copy project dependencies and source (Environment Parity requirement)
COPY backend/pyproject.toml /app/backend/
COPY backend/src /app/backend/src

# Install all project dependencies in the builder environment
RUN cd /app/backend && pip install .[dev]

# Copy MCP service script and set as executable
COPY backend/src/aider_mcp_launcher.py /usr/local/bin/aider_mcp_launcher.py

# Set PYTHONPATH to include both project root and backend src
ENV PYTHONPATH=/app/backend/src:/app

# Default command (overridden by docker-compose)
CMD ["python", "-m", "aider_mcp_launcher"]
