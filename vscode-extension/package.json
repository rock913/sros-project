{
    "name": "auto-researcher",
    "displayName": "auto-researcher",
    "description": "AI-powered autonomous research agent",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.83.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "auto-researcher.showControlPanel",
                "title": "Show AI Control Panel",
                "icon": "$(chip)"
            },
            {
                "command": "auto-researcher.refreshAssetLibrary",
                "title": "Refresh Asset Library",
                "icon": "$(refresh)"
            },
            {
                "command": "auto-researcher.refreshManuscript",
                "title": "Refresh Manuscript",
                "icon": "$(refresh)"
            },
            {
                "command": "researchAgent.viewPaperDetails",
                "title": "View Paper Details",
                "icon": "$(book)"
            },
            {
                "command": "researchAgent.exportPapers",
                "title": "Export Papers",
                "icon": "$(export)"
            },
            {
                "command": "researchAgent.changeGrouping",
                "title": "Change Paper Grouping",
                "icon": "$(group-by-ref-type)"
            },
            {
                "command": "researchAgent.viewReport",
                "title": "View Report",
                "icon": "$(file-text)"
            },
            {
                "command": "researchAgent.exportReport",
                "title": "Export Report",
                "icon": "$(export)"
            },
            {
                "command": "researchAgent.compareReports",
                "title": "Compare Report Versions",
                "icon": "$(diff)"
            },
            {
                "command": "auto-researcher.showAnalytics",
                "title": "Show Analytics Dashboard",
                "icon": "$(graph)"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "auto-researcher-sidebar",
                    "title": "Auto Researcher",
                    "icon": "resources/icon.png"
                }
            ]
        },
        "views": {
            "auto-researcher-sidebar": [
                {
                    "id": "assetLibrary",
                    "name": "Asset Library",
                    "type": "tree"
                },
                {
                    "id": "manuscript",
                    "name": "Manuscript",
                    "type": "tree"
                }
            ]
        },
        "menus": {
            "view/title": [
                {
                    "command": "auto-researcher.showControlPanel",
                    "when": "view == 'auto-researcher-sidebar'",
                    "group": "navigation"
                },
                {
                    "command": "auto-researcher.showAnalytics",
                    "when": "view == assetLibrary || view == manuscript",
                    "group": "navigation@0"
                },
                {
                    "command": "auto-researcher.refreshAssetLibrary",
                    "when": "view == assetLibrary",
                    "group": "navigation@1"
                },
                {
                    "command": "researchAgent.changeGrouping",
                    "when": "view == assetLibrary",
                    "group": "navigation@2"
                },
                {
                    "command": "researchAgent.exportPapers",
                    "when": "view == assetLibrary",
                    "group": "1_export"
                },
                {
                    "command": "auto-researcher.refreshManuscript",
                    "when": "view == manuscript",
                    "group": "navigation"
                }
            ],
            "view/item/context": [
                {
                    "command": "researchAgent.viewPaperDetails",
                    "when": "view == assetLibrary && viewItem == paper",
                    "group": "inline"
                },
                {
                    "command": "researchAgent.viewPaperDetails",
                    "when": "view == assetLibrary && viewItem == paper",
                    "group": "1_view@1"
                },
                {
                    "command": "researchAgent.exportPapers",
                    "when": "view == assetLibrary && viewItem == paper",
                    "group": "2_export@1"
                },
                {
                    "command": "researchAgent.viewReport",
                    "when": "view == manuscript && viewItem == report",
                    "group": "inline"
                },
                {
                    "command": "researchAgent.viewReport",
                    "when": "view == manuscript && viewItem == report",
                    "group": "1_view@1"
                },
                {
                    "command": "researchAgent.exportReport",
                    "when": "view == manuscript && viewItem == report",
                    "group": "2_export@1"
                },
                {
                    "command": "researchAgent.compareReports",
                    "when": "view == manuscript && viewItem == report",
                    "group": "2_export@2"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "xvfb-run --auto-servernum vscode-test",
        "test-e2e": "vscode-test"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.6",
        "@types/node": "18.x",
        "@types/sinon": "^17.0.4",
        "@types/vscode": "^1.83.0",
        "@typescript-eslint/eslint-plugin": "^6.19.1",
        "@typescript-eslint/parser": "^6.19.1",
        "@vscode/test-cli": "^0.0.4",
        "@vscode/test-electron": "^2.3.9",
        "eslint": "^8.56.0",
        "sinon": "^21.0.0",
        "typescript": "^5.3.3"
    },
    "dependencies": {
        "@types/ws": "^8.18.1",
        "axios": "^1.12.2",
        "ws": "^8.18.3"
    }
}
