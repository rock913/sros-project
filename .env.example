# ============================================================================
# 环境变量配置文件 (.env)
# ============================================================================
# 版本: Phase 3.5.4
# 最后更新: 2025-10-14
# 
# 使用说明:
#   1. 复制此文件为 .env
#   2. 取消注释需要的变量（删除 # 符号）
#   3. 填写实际的值
#   4. 不要提交 .env 文件到 Git
#
# 优先级:
#   环境变量 > .env 文件 > 默认值
# ============================================================================

# ----------------------------------------------------------------------------
# 🤖 AI 服务配置
# ----------------------------------------------------------------------------

# Gemini API 密钥（必需）
# 获取: https://makersuite.google.com/app/apikey
# 用途: LLM调用、文献理解、报告生成
#GEMINI_API_KEY=your-gemini-api-key-here

# SiliconFlow API 密钥（可选）
# 获取: https://cloud.siliconflow.cn
# 用途: 备用LLM服务
#SILICONFLOW_API_KEY=your-siliconflow-api-key-here

# ----------------------------------------------------------------------------
# 📊 可观测性配置
# ----------------------------------------------------------------------------

# LangSmith API 密钥（可选，推荐）
# 获取: https://smith.langchain.com/settings
# 用途: LangGraph trace追踪、性能监控、调试
# 影响功能: Phase 4.1 LangSmith集成
#LANGSMITH_API_KEY=your-langsmith-api-key-here

# LangSmith 项目名称（可选）
# 默认值: gemini-fullstack-langgraph
#LANGSMITH_PROJECT=gemini-fullstack-langgraph

# LangFuse 可观测性配置（Phase 4.1）
# 获取密钥: 
#   1. 访问 http://localhost:3000 (本地) 或 https://cloud.langfuse.com (云端)
#   2. 登录后进入 Settings → API Keys
#   3. 创建新密钥或复制现有密钥
# 用途: 端到端trace追踪、性能监控、HITL决策分析、文档协作监控
# 影响功能: Phase 4.1 LangFuse集成（HITL、报告生成、文档协作、WebSocket流式推送）
#LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxx
#LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxx
#LANGFUSE_HOST=http://localhost:3000

# 注意事项:
#   - LangSmith和LangFuse可以同时使用（互补）
#   - LangSmith: 偏重LangGraph工作流追踪
#   - LangFuse: 偏重业务指标和用户行为分析
#   - 如果只选一个，推荐使用LangFuse（开源、自托管、功能更全面）

# ----------------------------------------------------------------------------
# 🗄️ 数据库配置
# ----------------------------------------------------------------------------

# PostgreSQL 连接URI（必需）
# 格式: postgresql://username:password@host:port/database
# 开发环境默认值（Docker Compose）:
#POSTGRES_URI="postgresql://postgres:postgres@langgraph-postgres:5432/postgres"
# 本地开发（非Docker）:
#POSTGRES_URI="postgresql://postgres:postgres@localhost:5433/postgres"

# PostgreSQL 连接池配置（可选）
# 最大连接数
#POSTGRES_POOL_SIZE=10
# 连接超时（秒）
#POSTGRES_CONNECT_TIMEOUT=30

# ----------------------------------------------------------------------------
# 📦 缓存配置
# ----------------------------------------------------------------------------

# Redis 连接URI（可选）
# 格式: redis://host:port/db
# 开发环境默认值（Docker Compose）:
#REDIS_URI="redis://redis:6379/0"
# 本地开发（非Docker）:
#REDIS_URI="redis://localhost:6379"

# Redis 缓存过期时间（秒，默认: 3600 = 1小时）
#REDIS_CACHE_TTL=3600

# ----------------------------------------------------------------------------
# 📚 文献检索配置
# ----------------------------------------------------------------------------

# Unpaywall Email（必需）
# 用途: 访问 Unpaywall API 获取开放获取论文
# 格式: 有效的邮箱地址
# 注意: Unpaywall要求提供邮箱以防滥用
#UNPAYWALL_EMAIL=your-email@example.com

# ----------------------------------------------------------------------------
# 🔖 Zotero 集成配置（可选）
# ----------------------------------------------------------------------------

# Zotero Library ID
# 获取: https://www.zotero.org/settings/keys
# 用途: 同步论文到Zotero文献管理器
#ZOTERO_LIBRARY_ID=your-library-id

# Zotero Library Type
# 可选值: user | group
# 说明: user=个人库, group=群组库
#ZOTERO_LIBRARY_TYPE=user

# Zotero API Key
# 获取: https://www.zotero.org/settings/keys（创建新密钥）
# 权限: 需要"允许写入库访问"权限
#ZOTERO_API_KEY=your-zotero-api-key

# ----------------------------------------------------------------------------
# ⚡ 性能优化配置（Phase 3.5.4）
# ----------------------------------------------------------------------------

# WebSocket 心跳间隔（秒，默认: 30）
# 用途: 防止长时间研究任务导致连接超时
# 建议值: 30-60秒
#WEBSOCKET_HEARTBEAT_INTERVAL=30

# 会话详情事件限制（默认: 50）
# 用途: Session Details API 返回的最大事件数
# 影响: 响应大小、加载速度
#SESSION_DETAILS_EVENT_LIMIT=50

# API 请求超时（秒，默认: 300 = 5分钟）
# 用途: 长时间研究任务的超时限制
#API_REQUEST_TIMEOUT=300

# ----------------------------------------------------------------------------
# 💰 成本追踪配置（Phase 3.5.4）
# ----------------------------------------------------------------------------

# LLM 单价配置（USD per 1000 tokens）
# Gemini Pro 定价（参考）:
#LLM_INPUT_TOKEN_PRICE=0.00025
#LLM_OUTPUT_TOKEN_PRICE=0.0005

# 成本告警阈值（USD，默认: 1.0）
# 用途: 当单次研究成本超过此值时发出警告
#COST_ALERT_THRESHOLD=1.0

# ----------------------------------------------------------------------------
# 🌐 后端服务配置
# ----------------------------------------------------------------------------

# 后端服务端口（默认: 8121）
#BACKEND_PORT=8121

# 后端服务主机（默认: 0.0.0.0）
#BACKEND_HOST=0.0.0.0

# CORS 允许的源（逗号分隔，默认: *）
# 生产环境建议设置具体域名
#CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 日志级别（默认: INFO）
# 可选值: DEBUG | INFO | WARNING | ERROR | CRITICAL
#LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# 🏭 生产环境专用配置
# ----------------------------------------------------------------------------

# 环境标识（默认: development）
# 可选值: development | staging | production
#ENVIRONMENT=development

# 数据库连接使用SSL（生产环境推荐）
#POSTGRES_SSL_MODE=require

# Redis 连接使用SSL（生产环境推荐）
#REDIS_SSL=true

# API 速率限制（请求/分钟，默认: 60）
#RATE_LIMIT_PER_MINUTE=60

# 启用健康检查详细信息（默认: true）
# 设为false可隐藏敏感依赖信息
#HEALTH_CHECK_VERBOSE=true

# ----------------------------------------------------------------------------
# 🧪 开发/测试专用配置
# ----------------------------------------------------------------------------

# 启用调试模式（默认: false）
# 警告: 生产环境必须设为false
#DEBUG=false

# 启用热重载（默认: true in development）
#HOT_RELOAD=true

# 测试数据库URI（可选）
# 用于运行测试时使用独立数据库
#TEST_POSTGRES_URI="postgresql://postgres:postgres@localhost:5433/test_db"

# 模拟模式（跳过真实API调用，用于测试）
#MOCK_MODE=false

# ----------------------------------------------------------------------------
# 📝 示例配置（最小可运行）
# ----------------------------------------------------------------------------
# 
# 取消注释以下行即可快速启动（开发环境）:
#
# GEMINI_API_KEY=your-gemini-api-key-here
# POSTGRES_URI="postgresql://postgres:postgres@langgraph-postgres:5432/postgres"
# UNPAYWALL_EMAIL=your-email@example.com
#
# 可选但推荐:
# LANGSMITH_API_KEY=your-langsmith-api-key-here
# REDIS_URI="redis://redis:6379/0"
#
# ----------------------------------------------------------------------------

# ============================================================================
# 配置验证
# ============================================================================
# 
# 启动前验证配置:
#   make check-env  # 或
#   python backend/src/check_env.py
#
# 健康检查:
#   curl http://localhost:8121/health
#
# ============================================================================